{
  "name": "koda-codex",
  "version": "0.1.0",
  "description": "A plain-file phase gate that requires peer-review receipts before work advances.",
  "type": "module",
  "bin": {
    "koda": "./dist/cli.js"
  },
  "files": [
    "AGENTS.md",
    "LICENSE",
    "src",
    "dist",
    "demo",
    "docs",
    "scripts",
    "tests",
    ".agents/skills",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "node scripts/build.ts",
    "dogfood": "node scripts/run-dogfood.ts",
    "prepack": "npm run build",
    "reviewer:prepare": "node scripts/prepare-reviewer-run.ts",
    "reviewer:execute": "node scripts/execute-reviewer-run.ts",
    "test": "node --test tests/*.test.ts",
    "test:coverage": "node --experimental-test-coverage --test tests/*.test.ts",
    "test:record": "node scripts/run-tests-and-record.ts",
    "start": "node src/cli.ts"
  },
  "engines": {
    "node": ">=22.18"
  },
  "license": "GPL-3.0-only",
  "keywords": [
    "codex",
    "workflow",
    "peer-review",
    "cli"
  ]
}
