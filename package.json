{
  "name": "koda-codex",
  "version": "0.1.0",
  "description": "A plain-file phase gate that requires peer-review receipts before work advances.",
  "author": "Kristian Bengtsson",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freeborn-warrior/koda-codex.git"
  },
  "homepage": "https://github.com/freeborn-warrior/koda-codex#readme",
  "bugs": {
    "url": "https://github.com/freeborn-warrior/koda-codex/issues"
  },
  "type": "module",
  "bin": {
    "koda": "./dist/cli.js"
  },
  "files": [
    "AGENTS.md",
    "LICENSE",
    "README.md",
    "src",
    "dist",
    "demo",
    "docs",
    "scripts",
    "tests",
    ".agents/skills",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "node scripts/build.ts",
    "dogfood": "node scripts/run-dogfood.ts",
    "prepack": "npm run build",
    "relay:prepare": "node scripts/prepare-relay-run.ts",
    "relay:execute": "node scripts/execute-relay-run.ts",
    "relay:producer": "node scripts/execute-relay-run.ts --reviewer-window",
    "relay:reviewer": "node scripts/run-relay-reviewer-window.ts",
    "relay:status": "node scripts/show-relay-status.ts",
    "relay:review": "node scripts/read-relay-review.ts",
    "reviewer:prepare": "node scripts/prepare-reviewer-run.ts",
    "reviewer:execute": "node scripts/execute-reviewer-run.ts",
    "test": "node --test tests/*.test.ts",
    "test:coverage": "node --experimental-test-coverage --test tests/*.test.ts",
    "test:guide-preflight-model": "node scripts/run-guide-preflight-model-test.ts",
    "test:record": "node scripts/run-tests-and-record.ts",
    "start": "node src/cli.ts"
  },
  "engines": {
    "node": ">=22.18"
  },
  "license": "GPL-3.0-only",
  "keywords": [
    "codex",
    "workflow",
    "peer-review",
    "cli"
  ]
}
